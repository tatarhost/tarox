# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# CLOUDINARY_URL: Бесплатное облачное хранилище для медиафайлов.
# Зарегистрируйтесь на https://cloudinary.com/, скопируйте API Environment variable (CLOUDINARY_URL)
# и добавьте её в настройки секретов (Secrets) в AI Studio.
# Пример: cloudinary://123456789012345:abcdefghijklmnopqrstuvwxyz@cloud_name
CLOUDINARY_URL=""

# Twitch OAuth Credentials
# Создайте приложение на https://dev.twitch.tv/console
# Установите OAuth Redirect URI: <APP_URL>/auth/callback
TWITCH_CLIENT_ID=""
TWITCH_CLIENT_SECRET=""
